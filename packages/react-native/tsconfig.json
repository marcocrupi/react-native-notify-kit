{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext"],
    "allowJs": false,
    "jsx": "react-native",
    "declaration": true,
    "sourceMap": true,
    "listEmittedFiles": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": false,
    "isolatedModules": false,
    "strict": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "react-native": ["./../../apps/smoke/node_modules/react-native"],
      "react-native/*": ["./../../apps/smoke/node_modules/react-native/*"]
    }
  },
  "exclude": ["node_modules", "./src/__mocks__"],
  "include": ["./src"]
}
